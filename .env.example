# ——— 糯糯背单词 | 生产环境配置指南 ———

# 1. Supabase 基础配置 (必填)
# 从 Supabase Dashboard -> Settings -> API 获取
VITE_SUPABASE_URL=https://您的项目ID.supabase.co
VITE_SUPABASE_ANON_KEY=您的匿名公开密钥(anon_key)

# 2. 注册控制 (建议)
# 是否开启邀请码注册？ true = 必须输入有效邀请码； false = 仅凭手机/密码即可注册
VITE_REQUIRE_INVITE_CODE=true

# ——— 部署提醒 (Vercel / GitHub Pages) ———
# 1. 在 Vercel 的 Environment Variables 中填入上述 VITE_ 开头的变量。
# 2. 确保已在 Supabase SQL Editor 中运行以下迁移脚本：
#    - supabase_user_progress.sql (学习进度同步)
#    - supabase_license_rpc.sql (授权码激活逻辑)
# 3. 将授权码 CSV 导入到 Supabase 的 public.license_codes 表中。
