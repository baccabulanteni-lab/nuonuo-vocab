# 为云端同步（Supabase）准备的配置示例
VITE_SUPABASE_URL=https://<your-supabase-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# 登录/进度 API：留空则请求同源相对路径 /api（开发时由 Vite 代理到后端）
# 生产静态托管且 API 在另一域名时填写，例如 https://api.example.com（不要末尾斜杠）
# VITE_API_BASE_URL=

# 邀请码/授权码：默认需要（会请求 POST /api/auth/activate）。码应在你的后端或管理后台生成并入库，本前端不生成码。
# 若不做控量、希望用户只凭手机号+密码注册/登录，可设为 false（并请后端注册或登录时直接标记用户已激活，否则换设备登录会不一致）
# VITE_REQUIRE_INVITE_CODE=false

# —— 部署说明（Vercel 与授权码）——
# Vercel 上构建的是前端静态资源（见 vercel.json），不会上传本机 SQLite。
# 生产环境请：1）把 Node API（server/index.ts）部署到 Railway / Render / Fly 等可长期运行的主机；
# 2）在前端 Vercel 环境变量里设置 VITE_API_BASE_URL=https://你的-API-域名（无末尾斜杠）。
#
# 授权码放在 Supabase 表 public.license_codes 时，在「API 主机」上配置（勿提交到 Git、勿用 VITE_ 前缀）：
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role 密钥，仅服务端>
# 并在 Supabase SQL Editor 执行 server/supabase-license-migration.sql（增加 bound_username）。
# 可选：LICENSE_BOUND_USERNAME_COLUMN=bound_username
#
# 未配置上述两项时，授权码仍使用 API 主机上的 SQLite（仅适合本机开发）。
#
# ADMIN_KEY=nuonuo-admin-change-me
# API_PORT=8787
