{
  "name": "vocabulary-nuonuo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run api\" \"vite --host --port 3001\"",
    "dev:web": "vite --host --port 3001",
    "dev:all": "npm run dev",
    "api": "tsx server/index.ts",
    "tablet:url": "powershell -ExecutionPolicy Bypass -File scripts/tablet-dev-url.ps1",
    "share": "npx --yes localtunnel@2.0.2 --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "preview:all": "concurrently -n api,web -c cyan,magenta \"npm run api\" \"vite preview\"",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit",
    "build:vocab": "node scripts/build-vocab.mjs",
    "import:vocab": "node scripts/import-vocab-from-txt.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/canvas-confetti": "^1.9.0",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
